# Aliases
alias e="emacs"
alias et="emacs -nw"
# alias e="emacsclient -t"
# alias eg="emacsclient -c"
alias orgmode="e ~/Dokumenty/ObsidianVault/org"
alias chat-start="podman start ollama"
