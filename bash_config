# alias disk="du -sh -- * .[^.]* 2>/dev/null | sort -hr"
alias n="nvim"
alias org="y ~/Dokumenty/ObsidianVault/org"

# Functions
function y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
    yazi "$@" --cwd-file="$tmp"
    if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
        builtin cd -- "$cwd"
    fi
    rm -f -- "$tmp"
}

# History Settings
HISTSIZE=50000
HISTFILESIZE=500000
shopt -s histappend

# Keybinds
bind 'TAB:menu-complete'
bind '"\e[Z":menu-complete-backward'   # Shift+Tab cofa
