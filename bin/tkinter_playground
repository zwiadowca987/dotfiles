#!/usr/bin/env python3

'''
For future me,
the time has come. It is good moment to finally learn how place elements in tkinter.
Learn something more than PySimpleGUI.
'''

import tkinter

'''
How grid() works

col=0      col=1      col=2
        ┌──────────┬──────────┬──────────┐
row=0   │          │          │          │
        ├──────────┼──────────┼──────────┤
row=1   │          │          │          │
        ├──────────┼──────────┼──────────┤
row=2   │          │          │          │
        └──────────┴──────────┴──────────┘
'''

'''
Example

col=0       col=1
        ┌───────────┬────────────┐
row=0   │  Login:   │ [________] │
        ├───────────┼────────────┤
row=1   │  Hasło:   │ [________] │
        ├───────────┼────────────┤
row=2   │ [Zaloguj] │ [Anuluj]   │
        └───────────┴────────────┘
'''
okno = tkinter.Tk()
okno.title("Logowanie")

tkinter.Label(okno, text="Login:").grid(row=0, column=0)
tkinter.Entry(okno)              .grid(row=0, column=1)

tkinter.Label(okno, text="Hasło:").grid(row=1, column=0)
tkinter.Entry(okno, show="*")    .grid(row=1, column=1)

tkinter.Button(okno, text="Zaloguj").grid(row=2, column=0)
tkinter.Button(okno, text="Anuluj") .grid(row=2, column=1)

okno.mainloop()
