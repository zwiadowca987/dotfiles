#!/usr/bin/env python3

'''
For future me,
the time has come. It is good moment to finally learn something more than PySimpleGUI.
Here you have simple game in which you guess numbers (idk its name lol).
In future updates there will be more added.
'''

import tkinter as tk
import random


class GuessingGame:
    def __init__(self):
        self.window = tk.Tk()
        self.window.title('Guessing Game')

        self.correct = f'{random.randrange(0, 99999):05d}'

        self.create_widgets()

    def create_widgets(self):
        self.buttons = []
        for r in range(5):
            row = []
            for c in range(5):
                btn_id = f'{r}{c}'

                btn = tk.Button(
                    self.window,
                    text='0',
                    command=lambda id=btn_id: self.change(id),
                    state='disabled'
                )

                btn.grid(row=r, column=c, padx=10, pady=10)
                row.append(btn)

            check_btn = tk.Button(
                self.window,
                text='Check',
                command=lambda r=r: self.check(r),
                state='disabled'
            )

            check_btn.grid(row=r, column=5, padx=10, pady=10)
            row.append(check_btn)

            self.buttons.append(row)

        for i in range(6):
            self.buttons[0][i].config(state='normal')

    def change(self, id):
        btn = self.buttons[int(id[0])][int(id[1])]
        value = int(btn.cget('text'))
        value = value + 1 if value < 9 else 0
        btn.config(text=str(value))
    
    def check(self, id):
        for i in range(6):
            self.buttons[int(id)][i].config(state='disabled')

        input = ''
        for i in range(5):
            input += self.buttons[int(id)][i].cget('text')

        if input == self.correct:
            print('you won')
            return

        if id == 4:
            print('you lost')
            return

        for i in range(5):
            if input[i] not in self.correct:
                self.buttons[int(id)][i].config(bg='red')
            elif input[i] in self.correct and input[i] == self.correct[i]:
                self.buttons[int(id)][i].config(bg='green')
                self.buttons[int(id)+1][i].config(bg='green',
                                                  state='disabled',
                                                  text=self.buttons[int(id)][i].cget('text'))
            else:
                self.buttons[int(id)][i].config(bg='yellow')

        for i in range(6):
            self.buttons[int(id+1)][i].config(state='normal')

    def run(self):
        self.window.mainloop()


if __name__ == '__main__':
    app = GuessingGame()
    app.run()
