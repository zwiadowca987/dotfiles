#!/usr/bin/env python3
import sys
import subprocess

profiles = {
    "music": [
        "-x",
    ],

    "video": [
        "-f", "bestvideo+bestaudio/best",
        "--merge-output-format", "mp4",
    ],
}

def main():
    if len(sys.argv) < 3:
        print("yt <profile> <url>")
        sys.exit(1)

    profile = sys.argv[1]
    url = sys.argv[2]

    if profile not in profiles:
        print(f"Unknown profile: {profile}")
        sys.exit(1)

    print(f'yt {profile} {profiles[profile]}')
        
if __name__ == "__main__":
    main()
