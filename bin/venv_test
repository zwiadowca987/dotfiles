#!/bin/bash

# For future me,
# I was just testing theory, that will enable using venv in ~/bin/ software

set -euo pipefail

APP_DIR="$HOME/bin/venv_test_py"
VENV="$APP_DIR/.venv"

if [ ! -x "$VENV/bin/python" ]; then
    echo "Tworzenie środowiska virtualenv..."
    python3 -m venv "$VENV"
fi

"$VENV/bin/python" -m pip install --upgrade pip >/dev/null

if [ -f "$APP_DIR/requirements.txt" ]; then
    "$VENV/bin/pip" install -r "$APP_DIR/requirements.txt" --quiet
fi

exec "$VENV/bin/python" "$APP_DIR/app.py"
